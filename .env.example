# Telegram Bot Token (отримати у @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# NVIDIA NIM API
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=deepseek-ai/deepseek-v4-flash
NVIDIA_VISION_MODEL=meta/llama-3.2-11b-vision-instruct

# Ollama (локальний fallback)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_VISION_MODEL=llama3.2-vision:latest

# PostgreSQL
POSTGRES_USER=botuser
POSTGRES_PASSWORD=botpassword
POSTGRES_DB=medbot
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis (FSM Storage)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Шифрування даних
ENCRYPTION_KEY=your_fernet_key_here

# Webhook
WEBHOOK_HOST=your_server_ip
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=your_secret_key
WEBHOOK_PORT=8443

# Bucket
BACKUP_S3_BUCKET=<bucket_name>
BACKUP_S3_ENDPOINT_URL=your_url
BACKUP_S3_ACCESS_KEY=<Access Key>
BACKUP_S3_SECRET_KEY=<Secret Key>
BACKUP_S3_REGION=your_server
BACKUP_RETENTION_DAYS=14

# Feedback
ADMIN_CHAT_ID=<your_telegram_id>
